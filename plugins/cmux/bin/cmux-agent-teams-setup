#!/usr/bin/env bash
# cmux-agent-teams-setup: Configure Claude Code Agent Teams to use cmux panes
#
# This script sets up the environment so Claude Code's agent teams split-pane
# mode works with cmux instead of tmux. Run it once, or add to your shell profile.
#
# Usage:
#   eval "$(cmux-agent-teams-setup)"
#   # or add to ~/.zshrc:
#   eval "$(/path/to/cmux-agent-teams-setup)"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Only activate when inside cmux
if [[ -z "${CMUX_SURFACE_ID:-}" ]]; then
    echo "# Not inside cmux — agent teams setup skipped"
    exit 0
fi

cat <<SETUP
# cmux Agent Teams Configuration
# Generated by cmux-agent-teams-setup

# 1. Put the tmux shim ahead of real tmux in PATH
export PATH="${SCRIPT_DIR}:\$PATH"

# 2. Set TMUX so Claude Code detects "inside tmux" mode
#    This makes it use split-pane mode instead of in-process
export TMUX="cmux-shim"

# 3. Set TMUX_PANE to current surface ref
export TMUX_PANE="${CMUX_SURFACE_ID}"

# 4. Enable agent teams (in case not already set)
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# cmux agent teams ready — Claude Code will use cmux panes for teammates
SETUP
